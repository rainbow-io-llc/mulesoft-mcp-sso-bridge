# OAuth Bridge Server
PORT=3000

# Generate with: openssl rand -base64 32
JWT_SECRET=
SESSION_SECRET=

JWT_ISSUER=mulesoft-mcp-bridge
ACCESS_TOKEN_TTL=3600
AUTH_CODE_TTL=600

# Credentials for the OAuth login form (SSO user)
BRIDGE_USERNAME=admin
BRIDGE_PASSWORD=

# Anypoint Platform Connected App credentials
# Create at: Anypoint Platform > Access Management > Connected Apps
# Type: "App acts on its own behalf (client credentials)"
ANYPOINT_CLIENT_ID=
ANYPOINT_CLIENT_SECRET=
ANYPOINT_REGION=PROD_US

# Set to true to auto-patch ~/Library/Application Support/Claude/claude_desktop_config.json
UPDATE_CLAUDE_CONFIG=true
